# Supabase Configuration
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git (it's already in .gitignore)
#
# Zie docs/deployment.md voor instructies en waar je deze waarden vindt.

# Project URL - Find in Supabase Dashboard -> Project Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url

# Anon/Public Key - Find in Supabase Dashboard -> Project Settings -> API -> Project API keys -> anon/public
# This key is safe to use in the browser (it respects Row Level Security policies)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service Role Key - Find in Supabase Dashboard -> Project Settings -> API -> service_role key
# Server-only. Required in Phase 4+ for admin operations that bypass RLS.
# NEVER expose in client-side code or commit to git.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Productie-URL inclusief https:// (bijv. https://aiassistentenhub.nl). Lokaal: http://localhost:3000
# Gebruikt door metadataBase in app/layout.tsx en de RSS-feed (app/feed.xml/route.ts)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
