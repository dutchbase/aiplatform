# Secrets Pattern File for OpenClaw Workspace
# Format: regex pattern per line, case-insensitive matching

# Anthropic API Keys
sk-ant-[a-zA-Z0-9_-]{95,}

# OpenAI API Keys
sk-[a-zA-Z0-9]{20,}
sk-proj-[a-zA-Z0-9_-]{100,}

# AWS Access Keys
AKIA[0-9A-Z]{16}
(?:AWS|aws|Aws)?_?SECRET_?ACCESS_?KEY.{0,5}[=:]\s*['\"][A-Za-z0-9/+=]{40}['\"]

# GitHub Personal Access Tokens
ghp_[a-zA-Z0-9]{36}
github_pat_[a-zA-Z0-9]{22}_[a-zA-Z0-9]{59}

# Google API Keys
AIzaSy[a-zA-Z0-9_-]{33}

# ElevenLabs API Keys
sk_[a-f0-9]{48}

# Brave API Keys
BSA[a-zA-Z0-9]{20,}

# Generic patterns
password\s*[=:]\s*['\"][^'\"]{8,}['\"]
secret\s*[=:]\s*['\"][^'\"]{8,}['\"]
api[_-]?key\s*[=:]\s*['\"][^'\"]{16,}['\"]
token\s*[=:]\s*['\"][^'\"]{16,}['\"]
bearer\s+[a-zA-Z0-9_-]{20,}

# Private keys
-----BEGIN\s+(RSA|DSA|EC|OPENSSH|PGP)\s+PRIVATE\s+KEY-----

# JWT tokens (full tokens)
eyJ[a-zA-Z0-9_-]{10,}\.[a-zA-Z0-9_-]{10,}\.[a-zA-Z0-9_-]{10,}

# Slack tokens
xox[baprs]-[0-9]{10,13}-[0-9]{10,13}-[a-zA-Z0-9]{24,}

# Telegram bot tokens
[0-9]{8,10}:[a-zA-Z0-9_-]{35}

# Database connection strings
(?:postgres|mysql|mongodb|redis)://[^:\s]+:[^@\s]+@[^\s]+

# High-entropy strings (potential secrets)
# Matches: 40+ char alphanumeric strings that look random
(?<![a-zA-Z0-9])[a-zA-Z0-9+/=]{40,}(?![a-zA-Z0-9])
